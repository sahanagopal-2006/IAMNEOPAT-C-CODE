#include<iostream>
#include<string>
using namespace std;
int main(){
    string s;
    cin>>s;
    int zeroes=0;
    int ones=0;
    for(int i=0;i < s.length();i++){
        if(s[i]=='0'){
            zeroes++;
            
        }else{
            ones++;
        }
}
if(zeroes==1 || ones==1){
    cout<<"Yes";
    
}else{
    cout<<"No";
}
}
