#include<iostream>
using namespace std;
int main(){
    int n;
    cin>>n;
    if(n>10  || n<=0){
        cout<<"Invalid"<<endl;
        return 0;
        
    }
    int arr[10];
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    int max=arr[0];
    int min=arr[0];
    for(int i=1;i<n;i++){
        if(arr[i]>max)
            max=arr[i];
        if(arr[i]<min)
            min=arr[i];
    }
    cout<<"Max:"<<max<<endl;
    cout<<"Min:"<<min<<endl;
}
